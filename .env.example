# Coolify reads its own runtime environment from its UI, not from this file —
# this file documents which variables the stack expects so participants can
# see the contract. Never commit a real DSN with a private auth token.

# --- Sentry DSNs (PUBLIC ingestion endpoints, safe to expose) ---
SPRING_SENTRY_DSN=https://bf24f04f280201f59caae185d83a97eb@o4511643784511488.ingest.de.sentry.io/4511644672983120
ANGULAR_SENTRY_DSN=https://05129b1196d6b979d74c876edc341744@o4511643784511488.ingest.de.sentry.io/4511646810570832
ANDROID_SENTRY_DSN=https://9e8d71703ab027cf8474da46ffc220cd@o4511643784511488.ingest.de.sentry.io/4511645677453392
APPLE_IOS_SENTRY_DSN=https://fac0446447c22021f7c783bd7089f8e1@o4511643784511488.ingest.de.sentry.io/4511645257105488

# --- Sentry runtime config (shared) ---
SENTRY_ENVIRONMENT=training
SENTRY_TRACES_SAMPLE_RATE=1.0

# --- PolicyLab demo scenarios ---
DEMO_SCENARIOS_ENABLED=true
PARTICIPANT_ALIAS=anonymous

# --- Image pinning (used by compose.yaml) ---
# Set in Coolify to the SHA tag you want to deploy. Leave "main" to follow head.
IMAGE_TAG=main

# --- Sentry CI/CD auth (NEVER commit, NEVER paste into compose) ---
# Only GitHub Actions needs this, scoped org:ci, set in repo secrets:
# https://github.com/LucasMatuszewski/sentry-course-06-2026/settings/secrets/actions
SENTRY_AUTH_TOKEN=
